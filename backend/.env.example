# Hackathon Todo API - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Database Configuration (Required)
# =============================================================================

# Neon PostgreSQL (Production)
# Get your connection string from: https://console.neon.tech
DATABASE_URL=postgresql://user:password@host.db.neon.tech/dbname

# SQLite (Local Development - Alternative)
# DATABASE_URL=sqlite:///todo.db

# =============================================================================
# API Configuration (Required)
# =============================================================================

# Backend API URL
API_URL=http://localhost:8000

# CORS Origins (comma-separated)
# Add your frontend URLs here
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# HuggingFace API Configuration (Required for Phase III AI Chatbot)
# =============================================================================

# Get your token from: https://huggingface.co/settings/tokens
# Create a "read" token
HF_TOKEN=hf_your_huggingface_token_here

# Model to use (default: lightweight Qwen2.5)
HF_MODEL_ID=Qwen/Qwen2.5-0.5B-Instruct

# API request timeout in seconds
HF_API_TIMEOUT=30

# =============================================================================
# AI Configuration (Optional)
# =============================================================================

# Maximum conversation history messages to retrieve
MAX_CONVERSATION_HISTORY=50

# Maximum retry attempts for AI API calls
AI_MAX_RETRIES=3

# =============================================================================
# Deployment Notes
# =============================================================================

# For HuggingFace Spaces deployment:
# 1. Set HF_TOKEN in Space variables
# 2. Set DATABASE_URL in Space variables
# 3. Set CORS_ORIGINS to include your Space URL
# 4. Set API_URL to your Space URL

# For WSL Ubuntu:
# - No special configuration needed
# - Ensure port 8000 is not blocked by Windows firewall
# - Use localhost:8000 for local testing

# For Production:
# - Use strong DATABASE_URL with password
# - Set CORS_ORIGINS to your production domain
# - Keep HF_TOKEN secret (never commit to git)
